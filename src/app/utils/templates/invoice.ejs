<!DOCTYPE html>

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Order Invoice – Mission Bazar</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      background: #f4f4f4;
      margin: 0;
      padding: 20px;
      color: #333;
    }

    .wrapper {
  max-width: 620px;
  margin: 0 auto;
  background: #fff;
  border-radius: 6px;
  overflow: hidden;
}

.header {
  background: #1a1a2e;
  color: #fff;
  padding: 20px;
  text-align: center;
}

.header h1 {
  margin: 0;
  font-size: 22px;
  letter-spacing: 1px;
}

.body {
  padding: 24px;
}

.info-table {
  width: 100%;
  font-size: 13px;
  margin-bottom: 16px;
}

.info-table td {
  padding: 4px 0;
}

.label {
  color: #777;
  width: 40%;
}

.divider {
  border-top: 1px solid #e0e0e0;
  margin: 16px 0;
}

.product-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 13px;
  table-layout: fixed;
}

.product-table th {
  background: #1a1a2e;
  color: #fff;
  padding: 10px;
  text-align: left;
}

.product-table td {
  padding: 10px;
  border-bottom: 1px solid #eee;
  word-wrap: break-word;
}

.col-item { width: 40%; }
.col-qty { width: 15%; text-align: center; }
.col-price { width: 20%; text-align: right; }
.col-sub { width: 25%; text-align: right; }

.totals {
  margin-top: 16px;
  font-size: 13px;
}

.totals table {
  width: 100%;
}

.totals td {
  padding: 4px 0;
}

.totals .right {
  text-align: right;
}

.grand {
  font-size: 15px;
  font-weight: bold;
  color: #1a1a2e;
}

.cta {
  text-align: center;
  margin-top: 20px;
}

.cta a {
  background: #1a1a2e;
  color: #fff;
  padding: 10px 20px;
  text-decoration: none;
  border-radius: 4px;
  font-size: 13px;
}

.footer {
  background: #f4f4f4;
  text-align: center;
  padding: 14px;
  font-size: 11px;
  color: #888;
}


  </style>
</head>
<body>

<div class="wrapper">

  <div class="header">
    <h1>MISSION BAZAR</h1>
    <p>Your Trusted Online Marketplace</p>
  </div>

  <div class="body">

```
<p>Hi <strong><%= customerName %></strong>, thanks for your order!</p>

<table class="info-table">
  <tr>
    <td class="label">Transaction ID</td>
    <td><%= transactionId %></td>
  </tr>
  <tr>
    <td class="label">Order Date</td>
    <td><%= new Date(orderDate).toLocaleDateString('en-BD') %></td>
  </tr>
  <tr>
    <td class="label">Shipping Address</td>
    <td><%= shippingAddress %></td>
  </tr>
</table>

<div class="divider"></div>

<table class="product-table">
  <thead>
    <tr>
      <th class="col-item">Item</th>
      <th class="col-qty">Qty</th>
      <th class="col-price">Price</th>
      <th class="col-sub">Subtotal</th>
    </tr>
  </thead>
  <tbody>
    <% items.forEach(function(item){ %>
    <tr>
      <td class="col-item"><%= item.name %></td>
      <td class="col-qty"><%= item.quantity %></td>
      <td class="col-price">৳<%= item.price.toFixed(2) %></td>
      <td class="col-sub">৳<%= (item.price * item.quantity).toFixed(2) %></td>
    </tr>
    <% }); %>
  </tbody>
</table>

<div class="totals">
  <table>
    <tr>
      <td>Items Total</td>
      <td class="right">৳<%= itemsTotal.toFixed(2) %></td>
    </tr>
    <tr>
      <td>Shipping</td>
      <td class="right">৳<%= shippingCharge.toFixed(2) %></td>
    </tr>
    <tr class="grand">
      <td>Total Paid</td>
      <td class="right">৳<%= totalAmount.toFixed(2) %></td>
    </tr>
  </table>
</div>

<% if (invoiceUrl) { %>
<div class="cta">
  <a href="<%= invoiceUrl %>">Download Invoice</a>
</div>
<% } %>
```

  </div>

  <div class="footer">
    &copy; <%= new Date().getFullYear() %> Mission Bazar<br/>
    support@missionbazar.com
  </div>

</div>

</body>
</html>
