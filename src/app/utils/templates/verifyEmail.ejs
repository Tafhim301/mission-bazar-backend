<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <style>
    body { font-family: 'Segoe UI', Arial, sans-serif; background: #f4f4f4; margin: 0; padding: 0; }
    .wrapper { max-width: 560px; margin: 40px auto; background: #fff; border-radius: 12px; overflow: hidden; box-shadow: 0 4px 20px rgba(0,0,0,0.08); }
    .header { background: linear-gradient(135deg, #e91e8c, #c2185b); padding: 32px 40px; text-align: center; }
    .header h1 { color: #fff; margin: 0; font-size: 24px; letter-spacing: 1px; }
    .body { padding: 40px; }
    .greeting { font-size: 16px; color: #333; margin-bottom: 16px; }
    .otp-box { background: #fce4ec; border: 2px dashed #e91e8c; border-radius: 10px; padding: 24px; text-align: center; margin: 28px 0; }
    .otp-code { font-size: 40px; font-weight: 800; letter-spacing: 10px; color: #c2185b; }
    .otp-note { font-size: 13px; color: #888; margin-top: 8px; }
    .divider { border: none; border-top: 1px solid #f0f0f0; margin: 28px 0; }
    .footer { text-align: center; font-size: 12px; color: #aaa; padding: 0 40px 32px; }
  </style>
</head>
<body>
  <div class="wrapper">
    <div class="header"><h1>Mission Bazar</h1></div>
    <div class="body">
      <p class="greeting">Hi <strong><%= customerName %></strong>,</p>
      <p style="color:#555;">Welcome to Mission Bazar! Use the OTP below to verify your email address and activate your account.</p>
      <div class="otp-box">
        <div class="otp-code"><%= otp %></div>
        <div class="otp-note">This code expires in <strong>5 minutes</strong>. Do not share it with anyone.</div>
      </div>
      <hr class="divider">
      <p style="font-size:13px;color:#888;">If you did not create an account, you can safely ignore this email.</p>
    </div>
    <div class="footer">&copy; <%= new Date().getFullYear() %> Mission Bazar. All rights reserved.</div>
  </div>
</body>
</html>
